<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <EditText
        android:id="@+id/edtOperador"
        android:layout_width="0dp"
        android:layout_height=
        android:layout_marginTop="32dp"
        android:hint="Operador"
        app:layout_constraintEnd_toEndOf=
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/edtLinha"
        android:layout_width="0dp"
        android:layout_height=
        android:hint="Linha de Produção"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/edtOperador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtContador"
        android:layout_width=
        android:layout_height=
        android:text="Peças: 0"
        android:textSize="28sp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/edtLinha"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height=
        android:text="Iniciar Produção"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/txtContador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnPeca"
        android:layout_width="0dp"
        android:layout_height=
        android:text="Registrar Peça"
        android:enabled="false"
        android:layout_marginTop=
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnFinalizar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Finalizar Produção"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPeca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
